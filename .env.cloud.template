# ── .env.cloud — CLOUD_PROD environment ───────────────────────────────────────
# Copy to .env.production on your VPS/container and set COCKPIT_ENV=cloud.
# Build with: REACT_APP_COCKPIT_ENV=cloud npm run build
# Or set in CI environment variables before the build step.

REACT_APP_COCKPIT_ENV=cloud

# Replace with your server's public IP or domain
REACT_APP_API_ROOT=https://api.yourdomain.com
REACT_APP_WS_ROOT=wss://api.yourdomain.com

REACT_APP_STRATEGY_NAME=morning_strategy
REACT_APP_PORT=5000
REACT_APP_LOG_LEVEL=warn
REACT_APP_MARKET_OPEN_TIME=09:30
REACT_APP_MARKET_CLOSE_TIME=16:00
REACT_APP_TZ=America/New_York

# Optional: embed the build time for /health endpoint display
# REACT_APP_BUILD_TIME=2026-06-30T09:00:00Z
