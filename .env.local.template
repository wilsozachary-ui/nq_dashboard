# ── .env.local — LOCAL_DEV environment ────────────────────────────────────────
# Copy to .env.local and edit. Never commit .env.local to git.
# CRA automatically loads this file in `npm start`.
# Variables MUST use REACT_APP_ prefix to be accessible in the browser.

# Environment classifier (omit or set to anything other than cloud/sandbox for LOCAL_DEV)
# REACT_APP_COCKPIT_ENV=

# Backend API (Express server)
REACT_APP_API_ROOT=http://localhost:5000

# WebSocket root (derived from API_ROOT if omitted)
# REACT_APP_WS_ROOT=ws://localhost:5000

# Strategy identifier
REACT_APP_STRATEGY_NAME=morning_strategy

# Port the Express backend listens on (used for documentation; CRA dev server uses 3000)
REACT_APP_PORT=5000

# Log verbosity: debug | info | warn | error
REACT_APP_LOG_LEVEL=debug

# NYSE/CME session hours in HH:MM (America/New_York)
REACT_APP_MARKET_OPEN_TIME=09:30
REACT_APP_MARKET_CLOSE_TIME=16:00

# Timezone (informational — used in MarketOpenMode scheduler)
REACT_APP_TZ=America/New_York
