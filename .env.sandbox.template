# ── .env.sandbox — SANDBOX environment (prop-firm isolated) ───────────────────
# Copy to .env.production and set COCKPIT_ENV=sandbox before building.
# Build with: REACT_APP_COCKPIT_ENV=sandbox npm run build
#
# SANDBOX applies production-level optimizations (rate limiting, heartbeat
# watchdog, error suppression, auto-reconnect) regardless of NODE_ENV.
# Use for prop-firm evaluation accounts or isolated paper-trading sessions.

REACT_APP_COCKPIT_ENV=sandbox

# Point to the sandbox broker/sim API — never the live trading endpoint
REACT_APP_API_ROOT=http://sim-api.yourdomain.com:5000
REACT_APP_WS_ROOT=ws://sim-api.yourdomain.com:5000

REACT_APP_STRATEGY_NAME=morning_strategy_sandbox
REACT_APP_PORT=5001
REACT_APP_LOG_LEVEL=info
REACT_APP_MARKET_OPEN_TIME=09:30
REACT_APP_MARKET_CLOSE_TIME=16:00
REACT_APP_TZ=America/New_York
